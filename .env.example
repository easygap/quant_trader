# 프로젝트 루트에 이 파일을 복사한 뒤 .env 로 이름을 바꾸고 값을 채워 넣으세요.
# .env 파일은 Git에 올리지 마세요.

# --- KIS (한국투자증권) API ---
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# --- (선택) KIS API 호출 제한 ---
# MAX_CALLS_PER_SEC=10
# MAX_CALLS_PER_MIN=300
# MAX_RETRY=3

# --- 실전 모드 활성화 (live 모드 필수) ---
# ENABLE_LIVE_TRADING=true

# --- DART Open API (전자공시, 실적일 추정·공시 조회 폴백) ---
# https://opendart.fss.or.kr
DART_API_KEY=your_dart_api_key_here

# --- 디스코드 알림 웹훅 ---
DISCORD_WEBHOOK_URL=

# --- 이메일 알림 (SMTP, 디스코드 실패 시 폴백 / critical 시 병행) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=your_email@gmail.com

# --- (선택) 긴급 청산 HTTP 트리거 ---
# LIQUIDATE_TRIGGER_TOKEN=
# LIQUIDATE_TRIGGER_PORT=9090
