# ============================================================
# 퀀트 트레이더 - 설정 예시 (이 파일을 settings.yaml 로 복사 후 사용)
# ============================================================
# 중요: app_key, app_secret, account_no, webhook_url 은 환경변수에서만 로드됩니다.
# .env 에 KIS_APP_KEY, KIS_APP_SECRET, KIS_ACCOUNT_NO, DISCORD_WEBHOOK_URL 설정하세요.
# target-weight capped paper pilot은 Discord webhook이 비어 있으면 readiness/preflight 단계에서 차단됩니다.

kis_api:
  app_key: ""
  app_secret: ""
  account_no: "00000000-00"   # paper/호환 기본값. live 전략은 이 값으로 폴백하지 않음
  # live는 실행할 전략 키를 반드시 선언하고 번호는 .env로 주입합니다.
  # 선언되지 않은 KIS_ACCOUNT_NO_* 환경변수는 무시됩니다.
  accounts:
    scoring: ""               # .env: KIS_ACCOUNT_NO_SCORING=12345678-01
    # mean_reversion: ""       # .env: KIS_ACCOUNT_NO_MEAN_REVERSION=12345678-02
  base_url: "https://openapi.koreainvestment.com:9443"
  mock_url: "https://openapivts.koreainvestment.com:29443"
  use_mock: true
  # 요청 한도: KIS는 초당/분당 제한이 있음. 20~50종목 관리 시 한꺼번에 호출하면 차단 위험.
  # Token Bucket(초당) + 슬라이딩 윈도우(분당) 이중 제어. 환경변수 MAX_CALLS_PER_SEC / MAX_CALLS_PER_MIN 덮어쓰기 가능.
  max_calls_per_sec: 10      # 초당 최대 요청 (10~15 권장)
  max_calls_per_min: 300     # 분당 최대 요청 (KIS 분당 한도 이하로 설정)
  max_retry: 3

# --- 데이터베이스 설정 ---
# SQLite: WAL 모드(동시 읽기/쓰기) + busy_timeout(30s) + scoped_session(스레드 격리) 자동 적용
# 실전 안정화 후 PostgreSQL 전환 권장 (SQLAlchemy 연동 완료, type만 변경하면 전환)
database:
  type: "sqlite"                # "sqlite" 또는 "postgresql"
  sqlite_path: "data/quant_trader.db"
  backup_path: "data/backups"   # 설정 시 장마감 후 일일 백업 생성 (손상 시 복구용)
  backup_retention_days: 7      # 보관 일수, 초과 분 삭제
  # --- PostgreSQL 전환 시 아래 주석 해제 ---
  # type: "postgresql"
  # postgresql:
  #   host: "localhost"
  #   port: 5432
  #   database: "quant_trader"
  #   user: "quant_admin"
  #   password: "${DB_PASSWORD}"   # 환경변수 사용 권장

logging:
  level: "INFO"
  log_dir: "logs"
  rotation: "10 MB"
  retention: "30 days"
  console_output: true

# 데이터 소스 (수정주가 일치). FDR 우선 권장.
data_source:
  preferred: "auto"             # auto | fdr | yfinance | kis
  allow_kis_fallback: false     # true로 명시한 경우에만 KIS 비수정주가 폴백 허용
  warn_on_source_mismatch: true

trading:
  market_open: "09:00"
  market_close: "15:30"
  pre_market_prep: "08:50"
  block_open_30min: true
  block_close_30min: true
  mode: "paper"
  auto_entry: false
  pending_order_ttl_seconds: 600
  ledger_reconcile_guard_ttl_seconds: 86400  # 불명확/부분 체결·체결 후 장부 실패 시 최소 1일 중복 차단
  sync_broker_interval_minutes: 30   # live 모드에서 KIS 잔고와 DB 포지션 크로스체크 주기 (분)
  position_mismatch_auto_correct: false  # true면 KIS↔DB 불일치 시 DB를 KIS 기준으로 자동 보정. false면 알림만 발송.
  position_mismatch_allow_empty_broker_delete: false  # true면 KIS 보유 목록이 비어도 DB 포지션 자동 삭제 허용
  skip_earnings_days: 3             # 실적 발표일 전후 N일 신규 매수 금지 (0=비활성, yfinance→DART 기반)
  earnings_filter_unknown_policy: "block"  # 실적일 조회 불가 시 block(기본 fail-closed) 또는 allow
  blackswan_recovery_minutes: 120   # 블랙스완 쿨다운 해제 후 recovery 기간 (분)
  blackswan_recovery_scale: 0.5     # recovery 중 포지션 사이징 배수 (0.5 = 50%)
  # 시장 국면 필터 (단계적 대응): 3가지 독립 신호 중 2개↑ → bearish / 1개 → caution / 0 → bullish
  #   A. 200일선 이탈 / B. 단기 모멘텀 하락 / C. 단기 MA 데드크로스 (선택적)
  market_regime_filter: false                 # 검증 기준 기본 OFF. 활성화 시 백테스트도 같은 키를 기준으로 동기화
  market_regime_index: "KS11"
  market_regime_ma_days: 200
  market_regime_short_momentum_days: 20       # 신호 B: 단기 모멘텀 산출 기간
  market_regime_short_momentum_threshold: -5  # 신호 B: 수익률(%) 이하 시 하락 판단
  market_regime_caution_scale: 0.5            # caution 시 포지션 사이징 배수
  market_regime_ma_cross_enabled: true        # 신호 C: 단기 MA 크로스 활성화 (200일선보다 빠른 하락 감지)
  market_regime_ma_short: 20                  # 신호 C: 단기 이동평균 일수
  market_regime_ma_mid: 60                    # 신호 C: 중기 이동평균 일수

# DART Open API (실적 필터 yfinance 폴백). 키는 DART_API_KEY 환경변수 권장.
dart:
  api_key: ""
  enabled: true

# 알림: 디스코드 → 이메일 폴백 (critical 시 디스코드+이메일 동시)
# target-weight capped paper pilot은 DISCORD_WEBHOOK_URL 설정이 필수입니다.
discord:
  enabled: true
  webhook_url: ""

email:
  enabled: true
  smtp_server: ""
  smtp_port: 587
  smtp_user: ""
  alert_to: ""

# 웹 대시보드 (python main.py --mode dashboard)
dashboard:
  host: "127.0.0.1"  # 기본은 로컬 전용. 외부 공개는 reverse proxy/인증 구성 후 명시적으로 0.0.0.0 사용
  port: 8080

# 관심 종목(watchlist): 수작업 없이 시가총액·코스피200·모멘텀·저변동성 기준으로 자동 선정 가능
# mode: manual | top_market_cap | kospi200 | momentum_top | low_vol_top | momentum_lowvol
watchlist:
  mode: "top_market_cap"
  market: "KOSPI"
  top_n: 20
  # 리밸런싱 주기 (팩터 모드만 적용): Jegadeesh & Titman(1993) 기준 월 1회(≈20 거래일)
  rebalance_interval_days: 20    # 마지막 갱신 후 N일 경과 시 재계산 (data/watchlist_cache.json)
  # kospi200 모드 시: kospi200_top_n: 200  (기본 200)
  symbols:                 # manual 모드에서 사용. 자동 모드 실패 시 fallback
    - "005930"
    - "000660"
    - "035420"
